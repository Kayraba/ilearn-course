# Production environment example. Use placeholders only in source control.

NODE_ENV=production
PORT=3000
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME
JWT_SECRET=replace-with-random-48-byte-secret

SEED_ORG_NAME=Your Service Name
SEED_ORG_SLUG=your-service
SEED_ADMIN_NAME=Initial Admin Name
SEED_ADMIN_EMAIL=admin@example.org
SEED_ADMIN_PASSWORD=replace-with-strong-temporary-password

# Set after first real setup to avoid future automatic seeding.
# SEED_ON_BOOT=false

# Use if your provider requires SSL and is not auto-detected.
# PGSSL=true
