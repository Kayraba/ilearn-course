# Copy to .env for local development.

# PostgreSQL connection string. Locally:
DATABASE_URL=postgresql://ilearn:ilearn@127.0.0.1:5432/ilearn

# Secret used to sign JWTs. Mandatory in production.
# Generate one with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-me-in-production

# Configurable first-boot seed. Replace before any client/live use.
SEED_ORG_NAME=iLearn Pilot Service
SEED_ORG_SLUG=pilot
SEED_ADMIN_NAME=iLearn Service Admin
SEED_ADMIN_EMAIL=admin@example.org
SEED_ADMIN_PASSWORD=replace-with-strong-admin-password

# ElevenLabs voiceover generator (optional). Produces narration MP3s from
# src/narration.js for use in video editing — run once with: npm run voiceover
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=ssHwp0KCFDTGtFbiUYl6
# ELEVENLABS_MODEL=eleven_multilingual_v2

# Optional:
# NODE_ENV=production
# PORT=3000
# SEED_ON_BOOT=false
# PGSSL=true
